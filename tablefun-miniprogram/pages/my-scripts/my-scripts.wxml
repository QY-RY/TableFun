<!--pages/my-scripts/my-scripts.wxml-->
<view class="my-scripts-container">
  <!-- 未登录提示 -->
  <view class="login-tip" wx:if="{{!userInfo}}">
    <text class="tip-icon">👋</text>
    <text class="tip-text">登录后可查看我的收藏</text>
    <button class="btn-login" bindtap="goToLogin">去登录</button>
  </view>

  <!-- 已登录内容 -->
  <view wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-avatar">{{userInfo.nickname.charAt(0)}}</view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname}}</text>
        <text class="user-level">Lv.{{userInfo.level || 1}}</text>
      </view>
      <view class="user-stats">
        <view class="stat-item">
          <text class="stat-value">{{collectedScripts.length}}</text>
          <text class="stat-label">收藏</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{playedCount}}</text>
          <text class="stat-label">玩过</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{roomCount}}</text>
          <text class="stat-label">房间</text>
        </view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="function-grid">
      <view class="function-item" bindtap="goToMyRooms">
        <view class="function-icon">🏠</view>
        <text class="function-name">我的房间</text>
        <text class="function-count">{{roomCount}}</text>
      </view>
      <view class="function-item" bindtap="goToHistory">
        <view class="function-icon">📜</view>
        <text class="function-name">游戏记录</text>
        <text class="function-count">{{playedCount}}</text>
      </view>
      <view class="function-item" bindtap="goToAchievements">
        <view class="function-icon">🏆</view>
        <text class="function-name">成就</text>
        <text class="function-count">{{achievementCount}}</text>
      </view>
      <view class="function-item" bindtap="goToSettings">
        <view class="function-icon">⚙️</view>
        <text class="function-name">设置</text>
      </view>
    </view>

    <!-- 收藏剧本 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">⭐ 我的收藏</text>
        <text class="section-count">{{collectedScripts.length}}个剧本</text>
      </view>

      <scroll-view class="script-list" scroll-y wx:if="{{collectedScripts.length > 0}}">
        <view class="script-item" wx:for="{{collectedScripts}}" wx:key="id" bindtap="viewScriptDetail" data-id="{{item.id}}">
          <image class="script-cover" src="{{item.cover}}" mode="aspectFill" />
          <view class="script-info">
            <text class="script-name">{{item.name}}</text>
            <view class="script-tags">
              <text class="tag tag-type">{{item.type}}</text>
              <text class="tag tag-player">{{item.playerCount}}人</text>
            </view>
            <text class="script-rating">⭐ {{item.rating}}</text>
          </view>
          <view class="script-action" bindtap="removeCollect" data-id="{{item.id}}" catchtap="stopPropagation">
            <text>✕</text>
          </view>
        </view>
      </scroll-view>

      <!-- 空状态 -->
      <view class="empty-state" wx:else>
        <text class="empty-icon">⭐</text>
        <text class="empty-text">暂无收藏</text>
        <text class="empty-hint">去剧本库收藏喜欢的剧本吧</text>
        <button class="btn-go" bindtap="goToScriptList">去逛逛</button>
      </view>
    </view>
  </view>
</view>
