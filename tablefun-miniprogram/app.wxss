/**
 * 全局样式 - 清新白色主题
 * 适用范围：小程序所有页面
 */
 page {
  background-color: #f5f5f5; /* 页面整体背景色（浅灰），与app.json配置统一 */
  color: #333;               /* 全局默认文字色（深灰，提升阅读舒适度） */
  /* 全局字体：优先系统字体，保证多端显示一致性 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* ==================== 主题色样式 ==================== */
.theme-primary {
  color: #4CAF50; /* 主色调：绿色（与导航栏/标签栏选中色一致） */
}
.theme-secondary {
  color: #2196F3; /* 辅助色：蓝色（次要强调使用） */
}
.theme-accent {
  color: #FF9800; /* 强调色：橙色（重点/提醒使用） */
}

/* ==================== 按钮样式 ==================== */
/* 主按钮：主要操作按钮（如提交、确认） */
.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%); /* 渐变背景增强层次感 */
  color: #fff;               /* 文字白色 */
  border: none;              /* 去除默认边框 */
  border-radius: 50rpx;      /* 胶囊式圆角（适配小程序视觉风格） */
  padding: 24rpx 48rpx;      /* 内边距：上下24rpx 左右48rpx */
  font-size: 32rpx;          /* 字体大小（rpx适配不同屏幕） */
  font-weight: bold;         /* 文字加粗，突出按钮 */
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3); /* 轻微阴影增强立体感 */
}
/* 主按钮按压状态：模拟物理按钮反馈 */
.btn-primary:active {
  transform: scale(0.98); /* 按压时轻微缩小，提升交互体验 */
}

/* 次要按钮：次要操作（如取消、返回） */
.btn-secondary {
  background: #fff;          /* 白色背景 */
  color: #4CAF50;            /* 文字用主色调，保持视觉统一 */
  border: 2rpx solid #4CAF50; /* 2rpx绿色边框，区分主按钮 */
  border-radius: 50rpx;      /* 与主按钮统一圆角样式 */
  padding: 24rpx 48rpx;      /* 与主按钮统一尺寸 */
  font-size: 32rpx;          /* 字体大小统一 */
}

/* ==================== 通用容器 ==================== */
/* 卡片容器：用于包裹独立内容模块（如剧本列表项） */
.card {
  background: #fff;          /* 白色背景，区分页面底色 */
  border-radius: 20rpx;      /* 圆角设计，弱化直角 */
  padding: 30rpx;            /* 内边距，保证内容不贴边 */
  margin-bottom: 24rpx;      /* 底部外边距，卡片之间留空 */
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08); /* 轻阴影，增强层级 */
}

/* 输入框：表单输入通用样式 */
.input {
  background: #fff;          /* 白色背景 */
  border: none;              /* 去除默认边框 */
  border-radius: 12rpx;      /* 小圆角，符合输入框设计习惯 */
  padding: 24rpx;            /* 内边距，提升输入舒适度 */
  color: #333;               /* 输入文字色 */
  font-size: 28rpx;          /* 字体稍小于按钮，更适合阅读 */
}

/* ==================== 标签样式 ==================== */
/* 基础标签：通用样式，需配合分类类名使用 */
.tag {
  display: inline-block;     /* 行内块：支持并排+自定义内边距 */
  padding: 8rpx 20rpx;       /* 小内边距，适配标签尺寸 */
  border-radius: 20rpx;      /* 圆角，让标签更圆润 */
  font-size: 24rpx;          /* 小字体，标签无需过大 */
  margin-right: 12rpx;       /* 右侧间距，标签之间留空 */
  margin-bottom: 12rpx;      /* 底部间距，多行标签留空 */
}
/* 难度标签：橙色系（暖色调，对应强调色） */
.tag-difficulty {
  background: #FFF3E0;       /* 浅橙背景 */
  color: #FF9800;            /* 橙色文字 */
}
/* 类型标签：蓝色系（冷色调，对应辅助色） */
.tag-type {
  background: #E3F2FD;       /* 浅蓝背景 */
  color: #2196F3;            /* 蓝色文字 */
}
/* 人数标签：绿色系（主色调） */
.tag-player {
  background: #E8F5E9;       /* 浅绿背景 */
  color: #4CAF50;            /* 绿色文字 */
}

/* ==================== 适配样式 ==================== */
/* 底部安全区：适配异形屏（如iPhone底部小黑条） */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom); /* 兼容iOS < 11.2 */
  padding-bottom: env(safe-area-inset-bottom);       /* 兼容iOS >= 11.2 */
}