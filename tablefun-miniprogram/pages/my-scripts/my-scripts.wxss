/* pages/my-scripts/my-scripts.wxss */
.my-scripts-container {
  min-height: 100vh;
  background-color: #1a1a2e;
  padding-bottom: 100rpx;
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  padding: 40rpx;
}

.tip-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.tip-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 40rpx;
}

.btn-login {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, rgba(232, 69, 69, 0.2) 0%, rgba(192, 57, 43, 0.2) 100%);
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.user-level {
  font-size: 24rpx;
  color: #f7b731;
}

.user-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #e84545;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 功能网格 */
.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 20rpx 30rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 30rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.function-icon {
  font-size: 48rpx;
}

.function-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.function-count {
  font-size: 20rpx;
  color: #e84545;
  font-weight: bold;
}

/* 区域 */
.section {
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.section-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 剧本列表 */
.script-list {
  max-height: 500rpx;
}

.script-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.script-cover {
  width: 100rpx;
  height: 140rpx;
  border-radius: 12rpx;
}

.script-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.script-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.script-tags {
  display: flex;
  gap: 8rpx;
}

.script-rating {
  font-size: 24rpx;
  color: #f7b731;
}

.script-action {
  width: 50rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 30rpx;
}

.btn-go {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 26rpx;
}
