/* pages/home/home.wxss - 清新白色主题 */
.home-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 0 20rpx 20rpx;
  padding-bottom: 100rpx;
}

/* 城市选择器 */
.city-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 28rpx;
}

.city-name {
  font-weight: bold;
}

.city-arrow {
  font-size: 20rpx;
}

/* 搜索栏 */
.search-bar {
  position: relative;
  margin: 20rpx 0;
}

.search-input {
  width: 100%;
  height: 80rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 100rpx 0 40rpx;
  color: #333;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.placeholder {
  color: #999;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.filter-scroll {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  margin-bottom: 16rpx;
}

.filter-item {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.filter-item.active {
  background: #4CAF50;
  color: #fff;
}

.quick-filters {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.quick-filter {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  background: #FFF3E0;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #FF9800;
  border: 2rpx solid transparent;
}

.quick-filter.active {
  background: #FF9800;
  color: #fff;
  border-color: #FF9800;
}

/* 轮播图 */
.banner-swiper {
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.action-text {
  font-size: 24rpx;
  color: #333;
}

/* 区域 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #4CAF50;
}

/* 剧本滚动 */
.script-scroll {
  white-space: nowrap;
}

.script-card {
  display: inline-block;
  width: 280rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-right: 24rpx;
  vertical-align: top;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.script-cover {
  width: 100%;
  height: 360rpx;
}

.script-info {
  padding: 20rpx;
}

.script-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.script-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.script-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
}

.script-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rating-score {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF9800;
}

.rating-stars {
  font-size: 24rpx;
  color: #FF9800;
}

.rating-count {
  font-size: 22rpx;
  color: #999;
}

/* 房间列表 */
.room-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.room-cover {
  width: 160rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.room-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.room-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-script {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-text {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.status-playing {
  background: #FFEBEE;
  color: #F44336;
}

.status-waiting {
  background: #E8F5E9;
  color: #4CAF50;
}

.room-time,
.room-players {
  font-size: 24rpx;
  color: #666;
}

.room-badges {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.room-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.badge-special {
  background: #FFF3E0;
  color: #FF9800;
}

.badge-urgent {
  background: #FFEBEE;
  color: #F44336;
}

.badge-full {
  background: #E3F2FD;
  color: #2196F3;
}

.room-enter {
  width: 60rpx;
  height: 60rpx;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #4CAF50;
  flex-shrink: 0;
}

/* 最新剧本 */
.new-script-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.new-script-cover {
  width: 140rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.new-script-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.new-script-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.new-script-intro {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.new-script-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.new-script-time {
  font-size: 22rpx;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.city-modal,
.type-modal,
.sort-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 70vh;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  flex-direction: column;
  z-index: 101;
}

.date-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  z-index: 101;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

/* 城市列表 */
.city-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.city-section {
  margin-bottom: 30rpx;
}

.city-letter {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.city-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.city-item {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.city-item.active {
  background: #4CAF50;
  color: #fff;
}

/* 日期选择 */
.date-list {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
}

.date-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.date-item.active {
  background: #4CAF50;
  color: #fff;
}

.date-label {
  font-size: 28rpx;
  font-weight: bold;
}

.date-sub {
  font-size: 24rpx;
  color: #999;
}

.date-item.active .date-sub {
  color: rgba(255, 255, 255, 0.8);
}

/* 类型选择 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 20rpx;
}

.type-grid-item {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.type-grid-item.active {
  background: #4CAF50;
  color: #fff;
}

/* 排序选择 */
.sort-list {
  padding: 20rpx;
}

.sort-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.sort-item.active {
  background: #E8F5E9;
}

.sort-label {
  font-size: 28rpx;
  color: #333;
}

.sort-item.active .sort-label {
  color: #4CAF50;
  font-weight: bold;
}

.sort-icon {
  font-size: 32rpx;
  color: #4CAF50;
}
