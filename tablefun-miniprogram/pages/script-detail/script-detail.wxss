/* pages/script-detail/script-detail.wxss */
.detail-container {
  min-height: 100vh;
  background-color: #1a1a2e;
  padding-bottom: 140rpx;
}

/* 封面图 */
.script-cover {
  width: 100%;
  height: 500rpx;
  display: block;
}

/* 信息区 */
.info-section {
  padding: 30rpx;
  background: linear-gradient(to bottom, transparent, #1a1a2e 50rpx);
  margin-top: -50rpx;
  position: relative;
  border-radius: 30rpx 30rpx 0 0;
}

.script-header {
  margin-bottom: 30rpx;
}

.script-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.script-name {
  flex: 1;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.3;
}

.collect-btn {
  font-size: 48rpx;
  color: #f7b731;
  padding-left: 20rpx;
}

.script-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #e84545;
}

/* 价格行 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.price-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #e84545;
}

.price-value.free {
  color: #2ecc71;
}

/* 区域 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.section-content {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.8);
}

/* 角色列表 */
.character-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.character-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.character-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  flex-shrink: 0;
}

.character-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.character-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.character-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.character-gender {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

/* 亮点特色 */
.features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(46, 204, 113, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2ecc71;
  font-size: 24rpx;
  flex-shrink: 0;
}

.feature-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: rgba(26, 26, 46, 0.95);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
}

.action-btn.primary {
  flex: 2;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  font-weight: bold;
}

.action-btn.secondary {
  flex: 1;
  background: rgba(255, 255, 255, 0.1);
  flex-direction: column;
  gap: 4rpx;
  color: #fff;
}

.btn-icon {
  font-size: 32rpx;
}
