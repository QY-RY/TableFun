/* pages/profile/profile.wxss - 清新白色主题 */
.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 未登录 */
.not-logged-in {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.login-bg {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(69, 160, 73, 0.1) 100%);
}

.bg-icon {
  font-size: 200rpx;
  opacity: 0.3;
}

.login-content {
  padding: 60rpx;
  text-align: center;
}

.welcome-text {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.sub-text {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.btn-login {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  border: none;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.btn-icon {
  font-size: 36rpx;
}

/* 用户信息头部 */
.user-header {
  display: flex;
  align-items: center;
  padding: 60rpx 30rpx;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.15) 0%, rgba(69, 160, 73, 0.15) 100%);
  background-color: #4CAF50;
}

.avatar-section {
  margin-right: 24rpx;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: #fff;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #4CAF50;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.info-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.action-section {
  margin-left: 20rpx;
}

.btn-edit {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 等级卡片 */
.level-card {
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.level-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.level-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF9800;
}

.level-name {
  font-size: 24rpx;
  color: #666;
}

.level-exp {
  font-size: 24rpx;
  color: #999;
}

.level-progress {
  margin-top: 10rpx;
}

/* 菜单列表 */
.menu-list {
  padding: 0 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-count {
  font-size: 24rpx;
  color: #4CAF50;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.menu-divider {
  height: 20rpx;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 20rpx;
}

.btn-logout {
  width: 100%;
  height: 80rpx;
  background: #fff;
  color: #666;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-logout:active {
  background: #f5f5f5;
}
