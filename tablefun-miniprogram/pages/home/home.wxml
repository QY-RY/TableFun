<!--pages/home/home.wxml-->
<view class="home-container">
  <!-- 城市选择 -->
  <view class="city-selector" bindtap="showCityPicker">
    <text class="city-name">{{currentCity}}</text>
    <text class="city-arrow">▼</text>
  </view>

  <!-- 搜索区域 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <input 
        type="text" 
        placeholder="搜索剧本/房间/类型" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        placeholder-class="search-placeholder"
      />
      <!-- 简化：searchKeyword.length > 0 → searchKeyword -->
      <button 
        wx:if="{{searchKeyword}}" 
        class="clear-btn" 
        bindtap="clearSearch"
      >×</button>
    </view>
    <button class="search-btn" bindtap="onSearchConfirm">搜索</button>
  </view>

  <!-- 搜索态：仅显示搜索结果，隐藏首页内容 -->
  <view wx:if="{{searchKeyword}}" class="search-result" catchtap="stopPropagation">
    <!-- 无结果提示 -->
    <view wx:if="{{!hasSearchResult}}" class="no-result">
      <text>暂无 "{{searchKeyword}}" 相关内容</text>
      <button class="reset-btn" bindtap="clearSearch">清空搜索</button>
    </view>

    <!-- 剧本搜索结果（修改：用searchResults.scripts，且改为wx:if） -->
    <view wx:if="{{searchResults.scripts.length > 0}}" class="result-section">
      <view class="section-title">剧本搜索结果</view>
      <!-- 重命名类名：script-scroll → search-script-scroll，避免冲突 -->
      <scroll-view scroll-x="true" class="search-script-scroll">
        <view wx:for="{{searchResults.scripts}}" wx:key="id" class="search-script-item" bindtap="viewScriptDetail" data-id="{{item.id}}">
          <image class="script-cover" src="{{item.cover}}" mode="aspectFill"></image>
          <view class="script-name">{{item.name}}</view>
          <view class="script-type">{{item.type}}</view>
          <view class="script-rating">★{{item.rating}}</view>
        </view>
      </scroll-view>
    </view>

    <!-- 房间搜索结果（修改：用searchResults.rooms，wx:if独立判断） -->
    <view wx:if="{{searchResults.rooms.length > 0}}" class="result-section">
      <view class="section-title">房间搜索结果</view>
      <!-- 重命名类名：room-item → search-room-item，避免冲突 -->
      <view wx:for="{{searchResults.rooms}}" wx:key="id" class="search-room-item" bindtap="viewRoomDetail" data-room="{{item}}">
        <image class="room-cover" src="{{item.scriptCover}}" mode="aspectFill"></image>
        <view class="room-info">
          <view class="room-name">{{item.name}}</view>
          <view class="script-name">{{item.scriptName}}</view>
          <view class="player-count">{{item.currentPlayers}}/{{item.maxPlayers}}</view>
          <view class="room-tags">
            <text wx:if="{{item.isSpecial}}" class="tag special">特价</text>
            <text wx:if="{{item.isUrgent}}" class="tag urgent">急车</text>
            <text wx:if="{{item.isFull}}" class="tag full">满车</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 默认态：无搜索关键词时显示首页内容 -->
  <view wx:elif="{{!searchKeyword}}">
    <!-- 筛选栏 -->
    <view class="filter-bar">
      <view class="filter-scroll">
        <view class="filter-item {{filterType === 'all' ? 'active' : ''}}" bindtap="selectFilter" data-type="all">全部</view>
        <view class="filter-item {{filterType === 'date' ? 'active' : ''}}" bindtap="selectFilter" data-type="date">📅 日期</view>
        <view class="filter-item {{filterType === 'area' ? 'active' : ''}}" bindtap="selectFilter" data-type="area">📍 区域</view>
        <view class="filter-item {{filterType === 'type' ? 'active' : ''}}" bindtap="selectFilter" data-type="type">🎭 类型</view>
        <view class="filter-item {{filterType === 'sort' ? 'active' : ''}}" bindtap="selectFilter" data-type="sort">🔃 排序</view>
      </view>
      <view class="quick-filters">
        <view class="quick-filter {{showSpecial ? 'active' : ''}}" bindtap="toggleSpecial">🎁 特价</view>
        <view class="quick-filter {{showUrgent ? 'active' : ''}}" bindtap="toggleUrgent">⚡ 急车</view>
        <view class="quick-filter {{showFull ? 'active' : ''}}" bindtap="toggleFull">🎯 即将满车</view>
      </view>
    </view>

    <!-- 轮播图 -->
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(0,0,0,0.3)" indicator-active-color="#4CAF50" autoplay circular>
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
        <view class="banner-content">
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-subtitle">{{item.subtitle}}</text>
        </view>
      </swiper-item>
    </swiper>

    <!-- 快捷入口 -->
    <view class="quick-actions">
      <view class="action-item" bindtap="goToScriptList">
        <view class="action-icon">📚</view>
        <text class="action-text">剧本库</text>
      </view>
      <view class="action-item" bindtap="goToCreateRoom">
        <view class="action-icon">🎮</view>
        <text class="action-text">开房</text>
      </view>
      <view class="action-item" bindtap="goToMyScripts">
        <view class="action-icon">⭐</view>
        <text class="action-text">我的收藏</text>
      </view>
      <view class="action-item" bindtap="goToProfile">
        <view class="action-icon">👤</view>
        <text class="action-text">个人中心</text>
      </view>
    </view>

    <!-- 热门剧本 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">🔥 热门剧本</text>
        <text class="section-more" bindtap="goToScriptList">更多 →</text>
      </view>
      <scroll-view class="script-scroll" scroll-x>
        <view class="script-card" wx:for="{{hotScripts}}" wx:key="id" bindtap="viewScriptDetail" data-id="{{item.id}}">
          <image class="script-cover" src="{{item.cover}}" mode="aspectFill" />
          <view class="script-info">
            <text class="script-name">{{item.name}}</text>
            <view class="script-tags">
              <text class="tag tag-type">{{item.type}}</text>
              <text class="tag tag-difficulty">{{item.difficulty}}</text>
            </view>
            <view class="script-meta">
              <text class="meta-item">👥 {{item.playerCount}}人</text>
              <text class="meta-item">⏱️ {{item.duration}}h</text>
            </view>
            <view class="script-rating">
              <text class="rating-score">{{item.rating}}</text>
              <text class="rating-stars">★★★★★</text>
              <text class="rating-count">{{item.playCount}}人玩过</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 进行中的房间（修复：删除无数据的item.time） -->
    <view class="section" wx:if="{{activeRooms.length > 0}}">
      <view class="section-header">
        <text class="section-title">🎯 进行中</text>
      </view>
      <view class="room-item" wx:for="{{activeRooms}}" wx:key="id" bindtap="enterRoom" data-room="{{item}}">
        <image class="room-cover" src="{{item.scriptCover}}" mode="aspectFill" />
        <view class="room-info">
          <text class="room-name">{{item.name}}</text>
          <text class="room-script">{{item.scriptName}}</text>
          <view class="room-status">
            <text class="status-text status-playing">进行中</text>
            <!-- 移除：{{item.time}}（无对应数据） -->
          </view>
        </view>
        <view class="room-enter">→</view>
      </view>
    </view>

    <!-- 推荐房间 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">🌟 推荐房间</text>
      </view>
      <view class="room-item" wx:for="{{recommendRooms}}" wx:key="id" bindtap="viewRoomDetail" data-room="{{item}}">
        <image class="room-cover" src="{{item.scriptCover}}" mode="aspectFill" />
        <view class="room-info">
          <text class="room-name">{{item.name}}</text>
          <text class="room-script">{{item.scriptName}}</text>
          <view class="room-status">
            <text class="status-text status-waiting">等待中</text>
            <text class="room-players">{{item.currentPlayers}}/{{item.maxPlayers}}人</text>
          </view>
          <view class="room-badges">
            <text class="room-badge badge-special" wx:if="{{item.isSpecial}}">🎁 特价</text>
            <text class="room-badge badge-urgent" wx:if="{{item.isUrgent}}">⚡ 急车</text>
            <text class="room-badge badge-full" wx:if="{{item.isFull}}">🎯 即将满车</text>
          </view>
        </view>
        <view class="room-enter">→</view>
      </view>
    </view>

    <!-- 最新剧本 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">✨ 最新上架</text>
      </view>
      <view class="new-script-item" wx:for="{{newScripts}}" wx:key="id" bindtap="viewScriptDetail" data-id="{{item.id}}">
        <image class="new-script-cover" src="{{item.cover}}" mode="aspectFill" />
        <view class="new-script-info">
          <text class="new-script-name">{{item.name}}</text>
          <text class="new-script-intro">{{item.intro}}</text>
          <view class="new-script-tags">
            <text class="tag tag-type">{{item.type}}</text>
            <text class="tag tag-player">{{item.playerCount}}人</text>
          </view>
          <text class="new-script-time">{{item.publishTime}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 城市选择弹窗 -->
<view class="modal-mask" wx:if="{{showCityModal}}" bindtap="hideCityModal">
  <view class="city-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">选择城市</text>
      <text class="modal-close" bindtap="hideCityModal">✕</text>
    </view>
    <scroll-view class="city-list" scroll-y>
      <view class="city-section" wx:for="{{cityData}}" wx:key="letter">
        <text class="city-letter">{{item.letter}}</text>
        <view class="city-items">
          <view class="city-item {{currentCity === city ? 'active' : ''}}" wx:for="{{item.cities}}" wx:for-item="city" wx:key="*this" bindtap="selectCity" data-city="{{city}}">
            {{city}}
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 日期选择弹窗 -->
<view class="modal-mask" wx:if="{{showDateModal}}" bindtap="hideDateModal">
  <view class="date-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">选择日期</text>
      <text class="modal-close" bindtap="hideDateModal">✕</text>
    </view>
    <view class="date-list">
      <view class="date-item {{selectedDate === item.value ? 'active' : ''}}" wx:for="{{dateOptions}}" wx:key="value" bindtap="selectDate" data-date="{{item.value}}">
        <text class="date-label">{{item.label}}</text>
        <text class="date-sub">{{item.sub}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 类型选择弹窗 -->
<view class="modal-mask" wx:if="{{showTypeModal}}" bindtap="hideTypeModal">
  <view class="type-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">选择类型</text>
      <text class="modal-close" bindtap="hideTypeModal">✕</text>
    </view>
    <view class="type-grid">
      <view class="type-grid-item {{selectedType === item ? 'active' : ''}}" wx:for="{{scriptTypes}}" wx:key="*this" bindtap="selectScriptType" data-type="{{item}}">
        {{item}}
      </view>
    </view>
  </view>
</view>

<!-- 排序选择弹窗 -->
<view class="modal-mask" wx:if="{{showSortModal}}" bindtap="hideSortModal">
  <view class="sort-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">排序方式</text>
      <text class="modal-close" bindtap="hideSortModal">✕</text>
    </view>
    <view class="sort-list">
      <view class="sort-item {{selectedSort === item.value ? 'active' : ''}}" wx:for="{{sortOptions}}" wx:key="value" bindtap="selectSort" data-sort="{{item.value}}">
        <text class="sort-label">{{item.label}}</text>
        <text class="sort-icon" wx:if="{{selectedSort === item.value}}">✓</text>
      </view>
    </view>
  </view>
</view>